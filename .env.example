# ============================================================
# Single source of truth for app configuration.
# Copy this file to .env and fill in real values.
# .env is gitignored — never commit secrets.
# ============================================================

# --- API Keys (required for backend at runtime) ---
STARTGG_API_KEY=your_startgg_api_key_here
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# --- Backend runtime config ---
# Restricts CORS to your CloudFront domain in production.
# Leave unset locally — falls back to allowing all origins.
# ALLOWED_ORIGIN=https://your-distribution.cloudfront.net

# --- Frontend (baked in at build time via Vite define) ---
# URL the browser uses to reach the backend.
# For local docker-compose: http://localhost:8080
# For production: your ALB DNS name or custom domain
VITE_BACKEND_URL=http://localhost:8080
VITE_APP_VERSION=local
